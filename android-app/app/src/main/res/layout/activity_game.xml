<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@android:color/darker_gray" />

    <ImageView
        android:id="@+id/characterPortrait"
        android:layout_width="200dp"
        android:layout_height="300dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="120dp"
        android:scaleType="fitEnd"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#80000000"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@android:color/transparent"
                android:contentDescription="返回" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/worldTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="世界名称"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/locationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前位置"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="@android:color/transparent"
                android:contentDescription="设置" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/perspectiveBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#80000000"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="视角: "
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/perspectiveContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

        </LinearLayout>

        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <LinearLayout
            android:id="@+id/callRequestLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#80FF9800"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/callRequestText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="XXX正在呼叫你..."
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Button
                android:id="@+id/acceptCallButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="接听"
                android:textSize="12sp"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/rejectCallButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:text="拒绝"
                android:textSize="12sp"
                android:backgroundTint="#F44336" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/inputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#CC000000"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/listenButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="@android:color/transparent"
                android:contentDescription="聆听"
                android:padding="8dp" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="输入消息..."
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:maxLines="4"
                android:textColor="@android:color/white"
                android:textColorHint="#AAAAAA"
                android:inputType="textMultiLine" />

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="@android:color/transparent"
                android:contentDescription="发送"
                android:padding="8dp" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
